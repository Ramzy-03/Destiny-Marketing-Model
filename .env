# Destiny AI Digital Marketing Manager - Configuration
# Copy this file to .env and fill in your API keys

# === OPERATION MODE ===
# Set to 'true' to enable real API calls, 'false' for demo mode
ENABLE_REAL_API_CALLS=false
DEMO_MODE=true

# === AI CONTENT GENERATION ===
# Get your API key from: https://console.anthropic.com/
CLAUDE_API_KEY=

# === FACEBOOK ===
# Get tokens from: https://developers.facebook.com/
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# === INSTAGRAM ===
# Instagram uses Facebook Graph API
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# === LINKEDIN ===
# Get credentials from: https://www.linkedin.com/developers/
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# === TWITTER/X ===
# Get API keys from: https://developer.twitter.com/
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# === GOOGLE ADS (Optional) ===
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=